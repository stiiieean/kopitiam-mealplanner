<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Admin Dashboard — Kopitiam</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #faf9f7;
      min-height: 100vh;
    }

    .navbar {
      background: #6b3f1f;
      color: white;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 32px;
    }

    .navbar .brand { font-size: 1.2rem; font-weight: 700; }
    .navbar a { color: white; text-decoration: none; font-size: 0.9rem; }
    .navbar a:hover { text-decoration: underline; }

    .container { max-width: 700px; margin: 40px auto; padding: 0 24px; }

    h1 { font-size: 1.5rem; color: #3b2008; margin-bottom: 20px; }

    .card {
      background: white;
      border: 1px solid #e0d9d0;
      border-radius: 10px;
      overflow: hidden;
    }

    table { width: 100%; border-collapse: collapse; }

    thead th {
      background: #6b3f1f;
      color: white;
      padding: 11px 16px;
      text-align: left;
      font-size: 0.88rem;
    }

    tbody tr { border-bottom: 1px solid #e0d9d0; }
    tbody tr:last-child { border-bottom: none; }

    tbody td { padding: 12px 16px; font-size: 0.88rem; color: #3b2008; vertical-align: middle; }

    .badge {
      display: inline-block;
      padding: 2px 10px;
      border-radius: 20px;
      font-size: 0.78rem;
      font-weight: 600;
    }

    .badge-admin { background: #f0e9df; color: #6b3f1f; border: 1px solid #e0d9d0; }
    .badge-user  { background: #f0f0f0; color: #888; border: 1px solid #ddd; }

    .role-form { display: flex; gap: 8px; align-items: center; }

    .role-form select {
      padding: 5px 10px;
      border: 1px solid #e0d9d0;
      border-radius: 6px;
      font-size: 0.82rem;
      color: #3b2008;
      background: #faf9f7;
      outline: none;
    }

    .role-form select:focus { border-color: #6b3f1f; }

    .role-form button {
      padding: 5px 12px;
      background: #6b3f1f;
      color: white;
      border: none;
      border-radius: 6px;
      font-size: 0.82rem;
      cursor: pointer;
    }

    .role-form button:hover { background: #3b2008; }

    .delete-btn {
      padding: 5px 12px;
      background: white;
      color: #c0392b;
      border: 1px solid #f5c6c2;
      border-radius: 6px;
      font-size: 0.82rem;
      cursor: pointer;
    }

    .delete-btn:hover { background: #fdf0ef; }

    .create-card {
      background: white;
      border: 1px solid #e0d9d0;
      border-radius: 10px;
      padding: 24px;
      margin-bottom: 28px;
    }

    .create-card h2 { font-size: 1.1rem; color: #3b2008; margin-bottom: 16px; }

    .create-form {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: flex-end;
    }

    .create-form input,
    .create-form select {
      padding: 8px 12px;
      border: 1px solid #e0d9d0;
      border-radius: 8px;
      font-size: 0.88rem;
      color: #3b2008;
      background: #faf9f7;
      outline: none;
    }

    .create-form input:focus,
    .create-form select:focus { border-color: #6b3f1f; }

    .create-form button {
      padding: 8px 18px;
      background: #6b3f1f;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 0.88rem;
      font-weight: 600;
      cursor: pointer;
    }

    .create-form button:hover { background: #3b2008; }
  </style>
</head>
<body>

  <nav class="navbar">
    <span class="brand">Kopitiam — Admin</span>
    <a href="/home">← Back to Home</a>
  </nav>

  <div class="container">

    <h1>User Management</h1>

    <% if (success) { %>
      <p style="color: green; margin-bottom: 14px;"><%= success %></p>
    <% } %>

    <% if (failure) { %>
      <p style="color: red; margin-bottom: 14px;"><%= failure %></p>
    <% } %>

    <!-- Create Account -->
    <div class="create-card">
      <h2>Create New Account</h2>

      <% if (createFailure) { %>
        <p style="color: red; font-size: 0.85rem; margin-bottom: 12px;"><%= createFailure %></p>
      <% } %>

      <form class="create-form" action="/admin/users/create" method="POST">
        <input type="text" name="userid" placeholder="User ID" value="<%= formData.userid %>" required>
        <input type="text" name="username" placeholder="Username" value="<%= formData.username %>" required>
        <input type="password" name="password" placeholder="Password" required>
        <select name="role">
          <option value="user"  <%= formData.role === 'user'  ? 'selected' : '' %>>user</option>
          <option value="admin" <%= formData.role === 'admin' ? 'selected' : '' %>>admin</option>
        </select>
        <button type="submit">Create</button>
      </form>
    </div>

    <div class="card">
      <table>
        <thead>
          <tr>
            <th>User ID</th>
            <th>Username</th>
            <th>Current Role</th>
            <th>Change Role</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
            <tr>
              <td><%= u.userid %></td>
              <td><%= u.username %></td>
              <td>
                <% if (u.role === 'admin') { %>
                  <span class="badge badge-admin">admin</span>
                <% } else { %>
                  <span class="badge badge-user">user</span>
                <% } %>
              </td>
              <td>
                <form class="role-form" action="/admin/users/<%= u._id %>/role" method="POST">
                  <select name="role">
                    <option value="user"  <%= u.role === 'user'  ? 'selected' : '' %>>user</option>
                    <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>admin</option>
                  </select>
                  <button type="submit">Save</button>
                </form>
              </td>
              <td>
                <% if (u.role === 'user') { %>
                  <form action="/admin/users/<%= u._id %>/delete" method="POST">
                    <button type="submit" class="delete-btn">Delete</button>
                  </form>
                <% } else { %>
                  <span style="color: #ccc; font-size: 0.82rem;">—</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  </div>

</body>
</html>
