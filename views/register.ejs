<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register — Kopitiam</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #faf9f7;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .navbar {
      background: #6b3f1f;
      color: white;
      padding: 14px 32px;
      font-size: 1.2rem;
      font-weight: 700;
    }

    .page {
      flex: 1;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .card {
      background: white;
      border: 1px solid #e0d9d0;
      border-radius: 12px;
      padding: 40px 36px;
      width: 100%;
      max-width: 380px;
    }

    h2 {
      color: #3b2008;
      font-size: 1.6rem;
      margin-bottom: 28px;
      text-align: center;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 14px;
      margin-bottom: 20px;
    }

    input[type="text"],
    input[type="password"] {
      width: 100%;
      padding: 12px 14px;
      border: 1px solid #e0d9d0;
      border-radius: 8px;
      font-size: 0.95rem;
      color: #3b2008;
      background: #faf9f7;
      outline: none;
      transition: border-color 0.2s;
    }

    input[type="text"]:focus,
    input[type="password"]:focus {
      border-color: #6b3f1f;
    }

    .checkbox-row {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.9rem;
      color: #555;
    }

    input[type="checkbox"] {
      width: 16px;
      height: 16px;
      accent-color: #6b3f1f;
      cursor: pointer;
    }

    button[type="submit"] {
      width: 100%;
      padding: 12px;
      background: #6b3f1f;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
    }

    button[type="submit"]:hover {
      background: #3b2008;
    }

    .error {
      color: #c0392b;
      font-size: 0.85rem;
      text-align: center;
      margin-bottom: 14px;
    }

    .link {
      text-align: center;
      margin-top: 18px;
      font-size: 0.88rem;
      color: #888;
    }

    .link a {
      color: #6b3f1f;
      text-decoration: none;
      font-weight: 600;
    }

    .link a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>

  <nav class="navbar">Kopitiam</nav>

  <div class="page">
    <div class="card">
      <h2>Register</h2>

      <% if (failure) { %>
        <p class="error"><%= failure %></p>
      <% } %>

      <form action="/register" method="POST">
        <div class="form-group">
          <input type="text" name="userid" placeholder="UserID" required>
          <input type="text" name="username" placeholder="Username" required>
          <input type="password" name="password" placeholder="Password" required>
          <label class="checkbox-row">
            <input type="checkbox" name="agree" required>
            Agree to Terms and Conditions
          </label>
        </div>
        <button type="submit">Register</button>
      </form>

      <div class="link">
        Already have an account? <a href="/login">Login</a>
      </div>
    </div>
  </div>

</body>
</html>
