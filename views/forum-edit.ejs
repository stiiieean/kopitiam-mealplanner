<!DOCTYPE html>
<html>
<head>
  <title>Edit Post</title>
</head>
<body>

  <h1>Edit Post</h1>

  <form action="/forum/edit/<%= post._id %>" method="POST">

    <label>Title:</label><br>
    <input type="text" name="title" value="<%= post.title %>" required><br><br>

    <label>Content:</label><br>
    <textarea name="content" required><%= post.content %></textarea><br><br>

    <button type="submit">Update</button>

    <form action="/forum/delete/<%= post._id %>" method="POST">
        <button type="submit">Delete</button>
    </form>

  </form>

  <a href="/forum/<%= post._id %>">Back</a>

</body>
</html>