<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Add Review — Kopitiam</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #faf9f7;
      min-height: 100vh;
    }

    .navbar {
      background: #6b3f1f;
      color: white;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 32px;
    }

    .navbar .brand { font-size: 1.2rem; font-weight: 700; }

    .navbar a {
      color: white;
      text-decoration: none;
      font-size: 0.9rem;
    }

    .navbar a:hover { text-decoration: underline; }

    .container {
      max-width: 560px;
      margin: 48px auto;
      padding: 0 24px;
    }

    .card {
      background: white;
      border: 1px solid #e0d9d0;
      border-radius: 12px;
      padding: 32px;
    }

    h1 {
      font-size: 1.4rem;
      color: #3b2008;
      margin-bottom: 24px;
    }

    .error {
      color: #c0392b;
      font-size: 0.85rem;
      margin-bottom: 16px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    label {
      font-size: 0.85rem;
      font-weight: 600;
      color: #555;
      margin-bottom: 4px;
      display: block;
    }

    input[type="text"],
    textarea,
    select {
      width: 100%;
      padding: 10px 14px;
      border: 1px solid #e0d9d0;
      border-radius: 8px;
      font-size: 0.92rem;
      color: #3b2008;
      background: #faf9f7;
      outline: none;
      font-family: inherit;
      transition: border-color 0.2s;
    }

    input[type="text"]:focus,
    textarea:focus,
    select:focus {
      border-color: #6b3f1f;
    }

    textarea { resize: vertical; }

    button[type="submit"] {
      width: 100%;
      padding: 11px;
      background: #6b3f1f;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 8px;
    }

    button[type="submit"]:hover { background: #3b2008; }
  </style>
</head>
<body>

  <nav class="navbar">
    <span class="brand">Kopitiam</span>
    <a href="/ratings/<%= storeId %>">← Back to <%= storeName %></a>
  </nav>

  <div class="container">
    <div class="card">
      <h1>Add Review for <%= storeName %></h1>

      <% if (error) { %>
        <p class="error"><%= error %></p>
      <% } %>

      <form action="/ratings/<%= storeId %>/review/new" method="POST">
        <input type="hidden" name="storeName" value="<%= storeName %>">

        <div class="form-group">
          <div>
            <label for="title">Title</label>
            <input type="text" id="title" name="title" maxlength="100" required>
          </div>

          <div>
            <label for="body">Review</label>
            <textarea id="body" name="body" rows="5" minlength="10" required></textarea>
          </div>

          <div>
            <label for="rating">Rating (1–5)</label>
            <select id="rating" name="rating" required>
              <option value="">-- Select --</option>
              <option value="1">1 — Poor</option>
              <option value="2">2 — Fair</option>
              <option value="3">3 — Average</option>
              <option value="4">4 — Good</option>
              <option value="5">5 — Excellent</option>
            </select>
          </div>

          <button type="submit">Submit Review</button>
        </div>
      </form>
    </div>
  </div>

</body>
</html>
