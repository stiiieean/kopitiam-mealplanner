<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Plan Meal — Kopitiam</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #faf9f7;
      min-height: 100vh;
    }

    .navbar {
      background: #6b3f1f;
      color: white;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 32px;
    }

    .navbar .brand { font-size: 1.2rem; font-weight: 700; }
    .navbar a { color: white; text-decoration: none; font-size: 0.9rem; }
    .navbar a:hover { text-decoration: underline; }

    .container { max-width: 560px; margin: 40px auto; padding: 0 24px; }

    h1 { font-size: 1.3rem; color: #3b2008; margin-bottom: 24px; }

    .slot-card {
      background: white;
      border: 1px solid #e0d9d0;
      border-radius: 12px;
      padding: 20px 24px;
      margin-bottom: 16px;
    }

    .slot-header {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 14px;
    }

    .slot-header .emoji { font-size: 1.1rem; }

    .slot-header h2 {
      font-size: 1rem;
      color: #3b2008;
      font-weight: 700;
    }

    .fields { display: flex; flex-direction: column; gap: 12px; }

    label { font-size: 0.82rem; font-weight: 600; color: #555; display: block; margin-bottom: 4px; }

    input[type="text"],
    input[type="number"],
    textarea {
      width: 100%;
      padding: 9px 12px;
      border: 1px solid #e0d9d0;
      border-radius: 8px;
      font-size: 0.9rem;
      color: #3b2008;
      background: #faf9f7;
      font-family: inherit;
      outline: none;
      transition: border-color 0.2s;
    }

    input:focus, textarea:focus { border-color: #6b3f1f; }
    textarea { resize: vertical; }

    .hint {
      font-size: 0.76rem;
      color: #aaa;
      margin-top: 3px;
    }

    .actions {
      background: white;
      border: 1px solid #e0d9d0;
      border-radius: 12px;
      padding: 20px 24px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .save-btn {
      width: 100%;
      padding: 11px;
      background: #6b3f1f;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
    }

    .save-btn:hover { background: #3b2008; }

    .delete-btn {
      width: 100%;
      padding: 10px;
      background: white;
      color: #c0392b;
      border: 1px solid #f5c6c2;
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
    }

    .delete-btn:hover { background: #fdf0ef; }
  </style>
</head>
<body>

  <nav class="navbar">
    <span class="brand">Kopitiam</span>
    <a href="/meal-planner">← Back to Calendar</a>
  </nav>

  <!-- Store names for autocomplete -->
  <datalist id="store-list">
    <% stores.forEach(store => { %>
      <option value="<%= store.name %>">
    <% }) %>
  </datalist>

  <div class="container">
    <h1>Plan Meals for <%= date %></h1>

    <form action="/meal-planner/<%= date %>" method="POST">

      <%
        const slotConfig = [
          { key: 'breakfast', label: 'Breakfast', emoji: '🌅' },
          { key: 'lunch',     label: 'Lunch',     emoji: '☀️'  },
          { key: 'dinner',    label: 'Dinner',     emoji: '🌙' },
          { key: 'supper',    label: 'Supper',     emoji: '🌃' }
        ];
      %>

      <% slotConfig.forEach(function(slot) {
        const saved = existingPlan && existingPlan[slot.key] ? existingPlan[slot.key] : null;
      %>
        <div class="slot-card">
          <div class="slot-header">
            <span class="emoji"><%= slot.emoji %></span>
            <h2><%= slot.label %></h2>
          </div>
          <div class="fields">
            <div>
              <label>Meal Name</label>
              <input type="text" name="<%= slot.key %>[mealName]" placeholder="e.g. Nasi Lemak" value="<%= saved ? saved.mealName : '' %>">
            </div>
            <div>
              <label>Store / Hawker Centre</label>
              <input type="text" name="<%= slot.key %>[storeName]" placeholder="Type or pick a store" list="store-list" value="<%= saved && saved.storeName ? saved.storeName : '' %>">
              <p class="hint">Pick an existing store or type a new one — it will be added to the Ratings Board automatically.</p>
            </div>
            <div>
              <label>Budget ($)</label>
              <input type="number" name="<%= slot.key %>[budget]" step="0.01" min="0" placeholder="0.00" value="<%= saved && saved.budget ? saved.budget : '' %>">
            </div>
            <div>
              <label>Notes</label>
              <textarea name="<%= slot.key %>[notes]" rows="2" placeholder="e.g. No chilli"><%= saved && saved.notes ? saved.notes : '' %></textarea>
            </div>
          </div>
        </div>
      <% }) %>

      <div class="actions">
        <button type="submit" class="save-btn">Save</button>

        <% if (existingPlan && Object.keys(existingPlan.toObject ? existingPlan.toObject() : existingPlan).some(k => ['breakfast','lunch','dinner','supper'].includes(k))) { %>
          <button type="button" class="delete-btn"
            onclick="document.getElementById('delete-form').submit()">
            Clear This Day
          </button>
        <% } %>
      </div>

    </form>

    <form id="delete-form" action="/meal-planner/<%= date %>/delete" method="POST" style="display:none;"></form>
  </div>

</body>
</html>
