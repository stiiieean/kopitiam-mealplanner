<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meal Planner — Kopitiam</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #faf9f7;
      min-height: 100vh;
    }

    .navbar {
      background: #6b3f1f;
      color: white;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 32px;
    }

    .navbar .brand { font-size: 1.2rem; font-weight: 700; }
    .navbar a { color: white; text-decoration: none; font-size: 0.9rem; }
    .navbar a:hover { text-decoration: underline; }

    .container { max-width: 900px; margin: 36px auto; padding: 0 24px; }

    .top-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 6px;
      flex-wrap: wrap;
      gap: 10px;
    }

    h1 { font-size: 1.5rem; color: #3b2008; }

    .month-nav { display: flex; gap: 10px; }
    .month-nav a {
      padding: 6px 14px;
      background: white;
      border: 1px solid #e0d9d0;
      border-radius: 7px;
      color: #6b3f1f;
      text-decoration: none;
      font-size: 0.88rem;
      font-weight: 600;
    }
    .month-nav a:hover { background: #f0e9df; }

    .budget { font-size: 0.88rem; color: #6b3f1f; font-weight: 600; margin-bottom: 18px; }

    table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border: 1px solid #e0d9d0;
      border-radius: 10px;
      overflow: hidden;
    }

    thead th {
      background: #6b3f1f;
      color: white;
      padding: 9px 0;
      font-size: 0.85rem;
      text-align: center;
    }

    tbody td {
      border: 1px solid #e0d9d0;
      vertical-align: top;
      height: 100px;
      padding: 7px;
      font-size: 0.8rem;
    }

    .day-num { font-weight: 700; color: #3b2008; margin-bottom: 4px; }
    .meal-name { color: #6b3f1f; font-weight: 600; }
    .meal-store, .meal-budget { color: #999; font-size: 0.76rem; }

    .day-link {
      display: inline-block;
      margin-top: 5px;
      font-size: 0.74rem;
      color: #6b3f1f;
      text-decoration: none;
      border: 1px solid #e0d9d0;
      border-radius: 4px;
      padding: 1px 7px;
    }
    .day-link:hover { background: #f0e9df; }

    .empty { background: #faf9f7; }
  </style>
</head>
<body>

  <nav class="navbar">
    <span class="brand">Kopitiam</span>
    <a href="/home">← Back to Home</a>
  </nav>

  <%
    const monthNames = ["January","February","March","April","May","June","July","August","September","October","November","December"];
    let prevMonth = month - 1, prevYear = year;
    if (prevMonth < 0) { prevMonth = 11; prevYear--; }
    let nextMonth = month + 1, nextYear = year;
    if (nextMonth > 11) { nextMonth = 0; nextYear++; }
  %>

  <div class="container">
    <div class="top-row">
      <h1>Meal Planner — <%= monthNames[month] %> <%= year %></h1>
      <div class="month-nav">
        <a href="/meal-planner?month=<%= prevMonth %>&year=<%= prevYear %>">← Prev</a>
        <a href="/meal-planner?month=<%= nextMonth %>&year=<%= nextYear %>">Next →</a>
      </div>
    </div>
    <p class="budget">Total Planned Spend: $<%= totalBudget.toFixed(2) %></p>

    <table>
      <thead>
        <tr><th>Sun</th><th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th><th>Fri</th><th>Sat</th></tr>
      </thead>
      <tbody>
        <tr>
          <% for (let i = 0; i < firstDay; i++) { %><td class="empty"></td><% } %>
          <% for (let day = 1; day <= daysInMonth; day++) {
            let mFormat = (month + 1).toString().padStart(2, '0');
            let dFormat = day.toString().padStart(2, '0');
            let dateString = `${year}-${mFormat}-${dFormat}`;
            let meal = calendar.has(dateString) ? calendar.get(dateString) : null;
          %>
            <td>
              <div class="day-num"><%= day %></div>
              <% if (meal) { %>
                <div class="meal-name"><%= meal.mealName %></div>
                <div class="meal-store"><%= meal.storeName %></div>
                <div class="meal-budget">$<%= meal.budget ? meal.budget.toFixed(2) : '0.00' %></div>
              <% } %>
              <a href="/meal-planner/<%= dateString %>" class="day-link"><%= meal ? 'Edit' : 'Add' %></a>
            </td>
          <% if ((day + firstDay) % 7 === 0) { %></tr><tr><% }
          }
          let rem = 7 - ((daysInMonth + firstDay) % 7);
          if (rem < 7) { for (let i = 0; i < rem; i++) { %><td class="empty"></td><% } } %>
        </tr>
      </tbody>
    </table>
  </div>

</body>
</html>
