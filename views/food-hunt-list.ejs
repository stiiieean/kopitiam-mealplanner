<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Food Hunt — Kopitiam</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body { font-family: 'Segoe UI', sans-serif; background: #faf9f7; min-height: 100vh; }

    .navbar {
      background: #6b3f1f; color: white;
      display: flex; justify-content: space-between; align-items: center;
      padding: 14px 32px;
    }
    .navbar .brand { font-size: 1.2rem; font-weight: 700; }
    .navbar a { color: white; text-decoration: none; font-size: 0.9rem; }
    .navbar a:hover { text-decoration: underline; }

    .container { max-width: 700px; margin: 40px auto; padding: 0 24px; }

    .top-row {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 24px;
    }

    h1 { font-size: 1.5rem; color: #3b2008; }

    .new-btn {
      padding: 9px 18px;
      background: #6b3f1f; color: white;
      border-radius: 8px; text-decoration: none;
      font-size: 0.9rem; font-weight: 600;
    }
    .new-btn:hover { background: #3b2008; }

    .hunt-card {
      background: white;
      border: 1px solid #e0d9d0;
      border-radius: 10px;
      padding: 20px 24px;
      margin-bottom: 14px;
    }

    .hunt-card .req {
      display: flex; flex-wrap: wrap; gap: 5px;
      margin-bottom: 6px;
    }

    .tag {
      background: #f0e9df; color: #6b3f1f;
      font-size: 0.78rem; padding: 2px 10px;
      border-radius: 20px; border: 1px solid #e0d9d0;
    }

    .hunt-card .meta {
      font-size: 0.82rem; color: #888; margin-bottom: 12px;
    }

    .hunt-card .top-pick {
      font-size: 0.85rem; color: #6b3f1f; font-weight: 600; margin-bottom: 12px;
    }

    .actions { display: flex; gap: 8px; }

    .view-btn {
      padding: 6px 14px;
      background: #6b3f1f; color: white;
      border-radius: 6px; text-decoration: none;
      font-size: 0.82rem; font-weight: 600;
    }
    .view-btn:hover { background: #3b2008; }

    .edit-btn {
      padding: 6px 14px;
      background: white; color: #6b3f1f;
      border: 1px solid #e0d9d0; border-radius: 6px;
      text-decoration: none; font-size: 0.82rem; font-weight: 600;
    }
    .edit-btn:hover { background: #f0e9df; }

    .delete-btn {
      padding: 6px 14px;
      background: white; color: #c0392b;
      border: 1px solid #f5c6c2; border-radius: 6px;
      font-size: 0.82rem; font-weight: 600; cursor: pointer;
    }
    .delete-btn:hover { background: #fdf0ef; }

    .empty { color: #aaa; font-size: 0.9rem; text-align: center; padding: 48px 0; }
  </style>
</head>
<body>

  <nav class="navbar">
    <span class="brand">Kopitiam</span>
    <a href="/home">← Back to Home</a>
  </nav>

  <div class="container">
    <div class="top-row">
      <h1>Food Hunt</h1>
      <a href="/food-hunt/new" class="new-btn">+ New Hunt</a>
    </div>

    <% if (hunts.length === 0) { %>
      <p class="empty">No food hunts yet. Start one to get store recommendations!</p>
    <% } else { %>
      <% hunts.forEach(function(hunt) { %>
        <div class="hunt-card">
          <div class="req">
            <% hunt.requirements.split(',').forEach(function(tag) { %>
              <span class="tag"><%= tag.trim() %></span>
            <% }) %>
          </div>
          <div class="meta">
            $<%= hunt.totalBudget.toFixed(2) %> budget &nbsp;·&nbsp;
            <%= hunt.numMeals %> meal<%= hunt.numMeals > 1 ? 's' : '' %> &nbsp;·&nbsp;
            $<%= (hunt.totalBudget / hunt.numMeals).toFixed(2) %> per meal &nbsp;·&nbsp;
            <%= new Date(hunt.createdAt).toLocaleDateString('en-SG', { day: 'numeric', month: 'short', year: 'numeric' }) %>
          </div>
          <% if (hunt.results.length > 0) { %>
            <div class="top-pick">
              Best combo: $<%= hunt.results[0].totalCost.toFixed(2) %> total
              (<%= hunt.results[0].stores.map(s => s.storeName).join(' + ') %>)
            </div>
          <% } else { %>
            <div class="top-pick" style="color:#aaa;">No matching combinations found</div>
          <% } %>
          <div class="actions">
            <a href="/food-hunt/<%= hunt._id %>" class="view-btn">View Results</a>
            <a href="/food-hunt/<%= hunt._id %>/edit" class="edit-btn">Edit</a>
            <form action="/food-hunt/<%= hunt._id %>/delete" method="POST" style="display:inline;">
              <button type="submit" class="delete-btn">Delete</button>
            </form>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

</body>
</html>
