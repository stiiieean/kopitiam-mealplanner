<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Reviews for <%= store.name %></title>
</head>
<body>
  <h2>Reviews</h2>

  <% if (store.reviews && store.reviews.length > 0) { %>
    <% store.reviews.forEach(review => { %>
      <div>
        <h3><%= review.title %> — <%= review.rating %> ★</h3>
        <p><%= review.body %></p>
        <small>
          By <%= review.userid ? review.userid.username : 'Anonymous' %> 
          on <%= new Date(review.timestamp).toLocaleDateString() %>
        </small>
        <br>

        <a href="/review/<%= review._id %>/edit">Edit</a>

        <form action="/review/<%= review._id %>/delete" method="POST" style="display:inline;">
          <button type="submit">Delete</button>
        </form>
      </div>
      <hr>
    <% }) %>
  <% } else { %>
    <p>No reviews yet. Be the first to add one!</p>
  <% } %>

  <a href="/ratings/<%= store._id %>/review/new">Add Review</a>
</body>
</html>