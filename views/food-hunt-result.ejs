<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Food Hunt Results — Kopitiam</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body { font-family: 'Segoe UI', sans-serif; background: #faf9f7; min-height: 100vh; }

    .navbar {
      background: #6b3f1f; color: white;
      display: flex; justify-content: space-between; align-items: center;
      padding: 14px 32px;
    }
    .navbar .brand { font-size: 1.2rem; font-weight: 700; }
    .navbar a { color: white; text-decoration: none; font-size: 0.9rem; }
    .navbar a:hover { text-decoration: underline; }

    .container { max-width: 680px; margin: 40px auto; padding: 0 24px; }

    /* Summary card */
    .summary-card {
      background: white; border: 1px solid #e0d9d0;
      border-radius: 12px; padding: 24px; margin-bottom: 24px;
    }

    .summary-card h1 { font-size: 1.3rem; color: #3b2008; margin-bottom: 12px; }

    .req-row {
      display: flex; flex-wrap: wrap; gap: 5px;
      margin-bottom: 16px;
    }

    .tag {
      background: #f0e9df; color: #6b3f1f;
      font-size: 0.78rem; padding: 2px 10px;
      border-radius: 20px; border: 1px solid #e0d9d0;
    }

    .summary-grid {
      display: grid; grid-template-columns: 1fr 1fr 1fr;
      gap: 12px; margin-bottom: 16px;
    }

    .stat {
      background: #faf9f7; border: 1px solid #e0d9d0;
      border-radius: 8px; padding: 12px; text-align: center;
    }
    .stat .value { font-size: 1.2rem; font-weight: 700; color: #3b2008; }
    .stat .label { font-size: 0.75rem; color: #888; margin-top: 2px; }

    .card-actions { display: flex; gap: 8px; }

    .edit-btn {
      padding: 7px 16px; background: white; color: #6b3f1f;
      border: 1px solid #e0d9d0; border-radius: 6px;
      text-decoration: none; font-size: 0.85rem; font-weight: 600;
    }
    .edit-btn:hover { background: #f0e9df; }

    .delete-btn {
      padding: 7px 16px; background: white; color: #c0392b;
      border: 1px solid #f5c6c2; border-radius: 6px;
      font-size: 0.85rem; font-weight: 600; cursor: pointer;
    }
    .delete-btn:hover { background: #fdf0ef; }

    /* Combination cards */
    h2 { font-size: 1.1rem; color: #3b2008; margin-bottom: 14px; }

    .combo-card {
      background: white; border: 1px solid #e0d9d0;
      border-radius: 12px; padding: 20px 24px;
      margin-bottom: 16px;
    }

    .combo-header {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 16px;
    }

    .combo-rank {
      font-size: 1rem; font-weight: 700; color: white;
      background: #6b3f1f; border-radius: 20px;
      padding: 3px 14px;
    }
    .combo-rank.r1 { background: #d4a017; }
    .combo-rank.r2 { background: #a8a9ad; }
    .combo-rank.r3 { background: #cd7f32; }

    .combo-total {
      text-align: right;
    }
    .combo-total .total-cost { font-size: 1.1rem; font-weight: 700; color: #3b2008; }
    .combo-total .savings { font-size: 0.8rem; color: #2e7d32; }

    /* Each meal row inside a combo */
    .meal-row {
      display: flex; align-items: flex-start; gap: 14px;
      padding: 12px 0;
      border-top: 1px solid #f0ece8;
    }

    .meal-row:first-of-type { border-top: none; padding-top: 0; }

    .meal-label {
      min-width: 80px; font-size: 0.82rem;
      font-weight: 700; color: #888;
      padding-top: 2px;
    }

    .meal-info { flex: 1; }

    .meal-info .store-name { font-size: 0.95rem; font-weight: 600; color: #3b2008; margin-bottom: 3px; }
    .meal-info .store-loc  { font-size: 0.78rem; color: #aaa; margin-bottom: 5px; }

    .store-tags { display: flex; flex-wrap: wrap; gap: 4px; }

    .meal-cost {
      font-size: 0.9rem; font-weight: 700; color: #6b3f1f;
      white-space: nowrap; padding-top: 2px;
    }

    .view-link {
      font-size: 0.75rem; color: #6b3f1f;
      text-decoration: none; white-space: nowrap;
      padding-top: 4px;
    }
    .view-link:hover { text-decoration: underline; }

    .no-results {
      background: white; border: 1px solid #e0d9d0;
      border-radius: 10px; padding: 36px;
      text-align: center; color: #888; font-size: 0.9rem;
    }
  </style>
</head>
<body>

  <nav class="navbar">
    <span class="brand">Kopitiam</span>
    <a href="/food-hunt">← Back to Food Hunt</a>
  </nav>

  <%
    const mealLabels = ['Breakfast', 'Lunch', 'Dinner', 'Supper'];
    const rankClass  = ['r1', 'r2', 'r3'];
  %>

  <div class="container">

    <!-- Hunt Summary -->
    <div class="summary-card">
      <h1>Food Hunt Results</h1>

      <div class="req-row">
        <% hunt.requirements.split(',').forEach(function(tag) { %>
          <span class="tag"><%= tag.trim() %></span>
        <% }) %>
      </div>

      <div class="summary-grid">
        <div class="stat">
          <div class="value">$<%= hunt.totalBudget.toFixed(2) %></div>
          <div class="label">Total Budget</div>
        </div>
        <div class="stat">
          <div class="value"><%= hunt.numMeals %></div>
          <div class="label">Meal<%= hunt.numMeals > 1 ? 's' : '' %></div>
        </div>
        <div class="stat">
          <div class="value">$<%= (hunt.totalBudget / hunt.numMeals).toFixed(2) %></div>
          <div class="label">Avg per Meal</div>
        </div>
      </div>

      <div class="card-actions">
        <a href="/food-hunt/<%= hunt._id %>/edit" class="edit-btn">Edit & Recalculate</a>
        <form action="/food-hunt/<%= hunt._id %>/delete" method="POST" style="display:inline;">
          <button type="submit" class="delete-btn">Delete</button>
        </form>
      </div>
    </div>

    <!-- Top 3 Combinations -->
    <h2>Top <%= hunt.results.length %> Combination<%= hunt.results.length !== 1 ? 's' : '' %></h2>

    <% if (hunt.results.length === 0) { %>
      <div class="no-results">
        No combinations found within your $<%= hunt.totalBudget.toFixed(2) %> budget.<br>
        Try increasing your budget or selecting different tags.
      </div>
    <% } %>

    <% hunt.results.forEach(function(combo, comboIndex) {
      const savings = hunt.totalBudget - combo.totalCost;
    %>
      <div class="combo-card">

        <div class="combo-header">
          <span class="combo-rank <%= rankClass[comboIndex] %>">
            #<%= comboIndex + 1 %> Best Combo
          </span>
          <div class="combo-total">
            <div class="total-cost">Total: $<%= combo.totalCost.toFixed(2) %></div>
            <div class="savings">$<%= savings.toFixed(2) %> under budget</div>
          </div>
        </div>

        <% combo.stores.forEach(function(store, mealIndex) { %>
          <div class="meal-row">
            <div class="meal-label"><%= mealLabels[mealIndex] || ('Meal ' + (mealIndex + 1)) %></div>

            <div class="meal-info">
              <div class="store-name"><%= store.storeName %></div>
              <div class="store-loc">📍 <%= store.location %></div>
              <% if (store.tags && store.tags.length > 0) { %>
                <div class="store-tags">
                  <% store.tags.forEach(function(tag) { %><span class="tag"><%= tag %></span><% }) %>
                </div>
              <% } %>
            </div>

            <div style="display:flex; flex-direction:column; align-items:flex-end; gap:4px;">
              <div class="meal-cost">$<%= store.storeBudget.toFixed(2) %></div>
              <a href="/ratings/<%= store.storeId %>" class="view-link">View →</a>
            </div>
          </div>
        <% }) %>

      </div>
    <% }) %>

  </div>

</body>
</html>
